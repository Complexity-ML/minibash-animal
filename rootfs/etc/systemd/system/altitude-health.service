[Unit]
Description=Write Altitude boot and desktop health snapshot
After=altitude-seed.service altitude-systemd-audit.service multi-user.target
Wants=altitude-seed.service

[Service]
Type=oneshot
Environment=ALTITUDE_HEALTH_REGISTRY=0
Environment=ALTITUDE_HEALTH_LOG=/run/altitude-health.log
ExecStart=/bin/altitude-health refresh
Nice=10
IOSchedulingClass=idle
