#!/usr/bin/env bash
# bdb front controller. Runtime storage is native BDB only.
set -euo pipefail

if [ -x /bin/bdbc ]; then
  case "${1:-}" in
    init|create|tables|schema|insert|select|dump|update|delete|drop|check|transact|version|--version)
      exec /bin/bdbc "$@"
      ;;
  esac
fi

case "${1:-}" in
  sql|query)
    shift
    exec /bin/bdbql "$@"
    ;;
esac

echo "bdb: commande inconnue: ${1:-}" >&2
exit 64
