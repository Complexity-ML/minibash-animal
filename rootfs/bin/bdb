#!/usr/bin/env bash
# bdb front controller.
#
# Default engine: C (`/bin/bdbc`) for the hot path.
# Fallback engine: Bash (`/bin/bdb.bash`) for portability and SQL parser work.
set -euo pipefail

ENGINE="${BDB_ENGINE:-auto}"

if [ "$ENGINE" != "bash" ] && [ -x /bin/bdbc ]; then
  case "${1:-}" in
    init|create|tables|schema|insert|select|dump|update|delete|drop|pack|version|--version)
      exec /bin/bdbc "$@"
      ;;
  esac
fi

case "${1:-}" in
  sql|query)
    shift
    exec /bin/bdbql "$@"
    ;;
esac

exec /bin/bdb.bash "$@"
