#!/usr/bin/env bash
# Registry-aware pointer helper for Altitude.
#
# The low-level uinput injector lives in /bin/movectl-uinput. This wrapper keeps
# an operator-visible trace in the registry and offers named UI targets.
set -u

BIN="${MOVECTL_UINPUT:-/bin/movectl-uinput}"
REG="${BDBREG_BIN:-/bin/bdbreg}"
OWNER=movectl
FIFO="${MOVECTL_FIFO:-/run/movectl.fifo}"
LOG="${MOVECTL_LOG:-/var/log/movectl.log}"

usage() {
  cat <<'EOF'
usage:
  movectl move DX DY [STEPS]
  movectl click [left]
  movectl nudge
  movectl home
  movectl daemon
  movectl stop-daemon
  movectl goto TARGET
  movectl click-target TARGET
  movectl status
  movectl targets

targets:
  control-health
  control-systemd-bridge
  control-gpu
  control-failures
  control-overview
EOF
}

now() { date +%s 2>/dev/null || echo 0; }

reg_set() {
  local path="$1" type="$2" value="$3"
  [ -x "$REG" ] || return 0
  "$REG" set "$path" "$type" "$value" "$OWNER" >/dev/null 2>&1 || true
}

record_action() {
  local action="$1" detail="${2:-}"
  reg_set /system/input/pointer/driver string movectl-uinput
  reg_set /system/input/pointer/last-action string "$action"
  reg_set /system/input/pointer/last-detail string "$detail"
  reg_set /system/input/pointer/updated-at int "$(now)"
}

record_delta() {
  local dx="$1" dy="$2"
  record_action move "dx=$dx dy=$dy"
  reg_set /system/input/pointer/last-dx int "$dx"
  reg_set /system/input/pointer/last-dy int "$dy"
}

target_delta() {
  case "$1" in
    control-overview)        echo "80 150 10" ;;
    control-failures)        echo "250 150 12" ;;
    control-systemd-bridge)  echo "650 150 16" ;;
    control-health)          echo "830 150 18" ;;
    control-gpu)             echo "1180 150 20" ;;
    *) return 1 ;;
  esac
}

cmd_status() {
  if [ -x "$REG" ]; then
    "$REG" list /system/input/pointer
  else
    echo "movectl: registry unavailable"
  fi
}

run_uinput() {
  [ -x "$BIN" ] || {
    echo "movectl: missing low-level injector: $BIN" >&2
    exit 69
  }
  "$BIN" "$@"
}

ensure_daemon() {
  [ -p "$FIFO" ] && return 0
  mkdir -p /run "$(dirname "$LOG")" 2>/dev/null || true
  "$BIN" daemon >>"$LOG" 2>&1 &
  local i
  for i in $(seq 1 30); do
    [ -p "$FIFO" ] && return 0
    sleep 0.1
  done
  echo "movectl: daemon did not create $FIFO" >&2
  exit 70
}

send_daemon() {
  ensure_daemon
  printf '%s\n' "$*" >"$FIFO"
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  move)
    [ "$#" -ge 2 ] || { usage >&2; exit 64; }
    send_daemon "move $*"
    record_delta "$1" "$2"
    ;;
  click)
    send_daemon "click ${1:-left}"
    record_action click "${1:-left}"
    ;;
  nudge)
    send_daemon "nudge"
    record_delta 280 0
    ;;
  home)
    send_daemon "move -5000 -5000 40"
    record_action home "top-left"
    reg_set /system/input/pointer/origin string top-left
    ;;
  daemon)
    ensure_daemon
    record_action daemon "$FIFO"
    ;;
  stop-daemon)
    [ -p "$FIFO" ] && printf '%s\n' quit >"$FIFO"
    record_action stop-daemon "$FIFO"
    ;;
  goto)
    [ "$#" -eq 1 ] || { usage >&2; exit 64; }
    target="$1"
    delta="$(target_delta "$target")" || {
      echo "movectl: unknown target: $target" >&2
      exit 64
    }
    set -- $delta
    dx="$1"
    dy="$2"
    steps="$3"
    "$0" home
    sleep 0.1
    send_daemon "move $dx $dy $steps"
    record_action goto "$target dx=$dx dy=$dy steps=$steps"
    reg_set /system/input/pointer/target string "$target"
    ;;
  click-target)
    [ "$#" -eq 1 ] || { usage >&2; exit 64; }
    target="$1"
    "$0" goto "$target"
    sleep 0.15
    "$0" click left
    record_action click-target "$target"
    ;;
  status)
    cmd_status
    ;;
  targets)
    printf '%s\n' control-overview control-failures control-systemd-bridge \
      control-health control-gpu
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 64
    ;;
esac
