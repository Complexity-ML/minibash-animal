#!/usr/bin/env bash
# Altitude Services - desktop GUI over the bdb `services` table (bash + yad).
# Surfaces the Altitude service DB inside GNOME: list state + start/stop/restart.
# Service control needs root (signals minit/PID1, writes /var/bdb), so the
# actions go through `sudo` (see /etc/sudoers.d/minibash-svc).
export BDB_PATH="${BDB_PATH:-/var/bdb}"
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
BDB=/bin/bdb

have() { command -v "$1" >/dev/null 2>&1; }

# bdb dump services columns: name command autostart restart desired status pid description
rows() {
  $BDB dump services 2>/dev/null | tail -n +2 \
    | awk -F'\t' '{print $6"\t"$1"\t"$5"\t"$7"\t"$8}'   # status name desired pid description
}

# Fallback to a terminal view if yad isn't present.
if ! have yad; then
  if have zenity; then
    zenity --text-info --title="Altitude Services" --width=720 --height=440 \
      --filename=<($BDB select services 2>/dev/null)
  else
    $BDB select services
  fi
  exit 0
fi

while true; do
  sel=$(rows | yad --list --title="Altitude Services (BDB)" \
        --width=760 --height=440 --separator="|" --print-column=2 \
        --column="État" --column="Service" --column="Voulu" --column="PID" --column="Description" \
        --button="▶ Démarrer:2" --button="■ Arrêter:3" --button="↻ Redémarrer:4" \
        --button="⟳ Rafraîchir:5" --button="Fermer:1")
  rc=$?
  svc="${sel%|}"
  case "$rc" in
    2) [ -n "$svc" ] && sudo /bin/bashsvc start "$svc" ;;
    3) [ -n "$svc" ] && sudo /bin/bashsvc stop "$svc" ;;
    4) [ -n "$svc" ] && sudo /bin/bashsvc restart "$svc" ;;
    5) : ;;            # refresh -> loop
    *) exit 0 ;;       # close / ESC
  esac
  sleep 0.3
done
