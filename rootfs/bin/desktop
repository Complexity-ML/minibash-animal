#!/usr/bin/env bash
# minibash desktop dashboard. Works in a plain TTY and inside a terminal.
set -u

BDB_PATH="${BDB_PATH:-/var/bdb}"
export BDB_PATH

hide_cursor() { printf '\033[?25l'; }
show_cursor() { printf '\033[?25h'; }
clear_screen() { printf '\033[2J\033[H'; }
reset_term() { show_cursor; printf '\033[0m\n'; }

trap reset_term EXIT INT TERM

draw() {
  local up="0" host="minibash" now services running down logs
  if [ -r /proc/uptime ] && read -r up _ < /proc/uptime; then up="${up%.*}"; fi
  if [ -r /proc/sys/kernel/hostname ]; then read -r host < /proc/sys/kernel/hostname; fi
  now="$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)"
  services="$(/bin/bdb dump services 2>/dev/null | tail -n +2 | wc -l | awk '{print $1}')"
  running="$(/bin/bdb dump services 2>/dev/null | tail -n +2 | awk -F '\t' '$6 == "running" { n++ } END { print n + 0 }')"
  down="$(/bin/bdb dump services 2>/dev/null | tail -n +2 | awk -F '\t' '$5 == "down" { n++ } END { print n + 0 }')"
  logs="$(/bin/bdb dump logs 2>/dev/null | tail -n +2 | wc -l | awk '{print $1}')"

  clear_screen
  printf '\033[1;37mminibash desktop\033[0m  %s  uptime=%ss  %s\n' "$host" "$up" "$now"
  printf 'services=%s running=%s desired-down=%s logs=%s\n\n' "$services" "$running" "$down" "$logs"
  printf '\033[1;36mServices\033[0m\n'
  printf '%-12s %-8s %-8s %-6s %s\n' NAME DESIRED STATUS PID DESCRIPTION
  /bin/bdb dump services 2>/dev/null | tail -n +2 \
    | awk -F '\t' '{ printf "%-12s %-8s %-8s %-6s %s\n", $1, $5, $6, $7, $8 }' \
    | sed -n '1,14p'
  printf '\n\033[1;36mRecent logs\033[0m\n'
  /bin/bdb dump logs 2>/dev/null | tail -n 8 | awk -F '\t' '{ printf "%s %-10s %s\n", $1, $2, $3 }'
  printf '\nCommands: r refresh | s shell | q quit\n'
  printf 'desktop> '
}

hide_cursor
while true; do
  draw
  IFS= read -r key || key=q
  case "$key" in
    q|Q|quit|exit) break ;;
    s|S|shell)
      reset_term
      /bin/bash -i
      hide_cursor
      ;;
    r|R|refresh|"") ;;
    *) printf 'unknown command: %s\n' "$key"; sleep 1 ;;
  esac
done
