#!/usr/bin/env gjs

imports.gi.versions.Gtk = '4.0';

const ByteArray = imports.byteArray;
const { Gio, GLib, Gtk } = imports.gi;

const ALT_IDE_BIN = GLib.getenv('ALT_IDE_BIN') || '/bin/alt-ide';

function bytesToString(bytes) {
    return bytes ? ByteArray.toString(bytes) : '';
}

function runSync(argv) {
    try {
        const [ok, stdout, stderr, status] =
            GLib.spawn_sync(null, argv, null, GLib.SpawnFlags.SEARCH_PATH, null);
        return {
            ok: ok && status === 0,
            text: `${bytesToString(stdout)}${bytesToString(stderr)}`,
            status,
        };
    } catch (e) {
        return { ok: false, text: `${e.message}\n`, status: 127 };
    }
}

function runAsync(argv, callback) {
    let proc;
    try {
        proc = new Gio.Subprocess({
            argv,
            flags: Gio.SubprocessFlags.STDOUT_PIPE | Gio.SubprocessFlags.STDERR_PIPE,
        });
        proc.init(null);
    } catch (e) {
        callback(`$ ${argv.join(' ')}\n\n${e.message}\n`);
        return;
    }

    proc.communicate_utf8_async(null, null, (source, result) => {
        try {
            const [, stdout, stderr] = source.communicate_utf8_finish(result);
            const status = source.get_exit_status();
            callback(`$ ${argv.join(' ')}\n\n${stdout || ''}${stderr || ''}${status === 0 ? '' : `\nexit: ${status}\n`}`);
        } catch (e) {
            callback(`$ ${argv.join(' ')}\n\n${e.message}\n`);
        }
    });
}

function shellSplit(text) {
    if (text.trim() === '')
        return [];
    try {
        const [, argv] = GLib.shell_parse_argv(text);
        return argv;
    } catch (_) {
        return text.trim().split(/\s+/);
    }
}

function escapeText(text) {
    return GLib.markup_escape_text(text, -1);
}

function parseWorkspaceRoot() {
    const result = runSync([ALT_IDE_BIN, 'workspace', 'status']);
    const line = result.text.split('\n').find(item => item.startsWith('root='));
    return line ? line.slice(5) : GLib.get_current_dir();
}

function loadActions() {
    const result = runSync([ALT_IDE_BIN, 'actions', 'list']);
    const lines = result.text.split('\n').filter(line => line.trim() !== '');
    return lines.map(line => {
        const parts = line.split('\t');
        return {
            id: parts[0] || 'unknown',
            label: parts[1] || parts[0] || 'unknown',
            command: parts[2] || '',
        };
    });
}

function loadFiles(query) {
    const argv = [ALT_IDE_BIN, 'files', 'list'];
    if (query.trim() !== '')
        argv.push(query.trim());
    const result = runSync(argv);
    if (!result.ok)
        return [];
    return result.text.split('\n')
        .map(line => line.trim())
        .filter(line => line !== '' && !line.startsWith('alt-ide:'));
}

function safeRelativePath(path) {
    return path !== '' &&
        !path.startsWith('/') &&
        path !== '.' &&
        !path.startsWith('../') &&
        !path.includes('/../') &&
        !path.endsWith('/..');
}

function pathInWorkspace(root, relpath) {
    return GLib.build_filenamev([root, relpath]);
}

function readFile(root, relpath) {
    if (!safeRelativePath(relpath))
        throw new Error(`unsafe path: ${relpath}`);
    const file = Gio.File.new_for_path(pathInWorkspace(root, relpath));
    const [ok, contents] = file.load_contents(null);
    if (!ok)
        throw new Error(`cannot read: ${relpath}`);
    return bytesToString(contents);
}

function writeFile(root, relpath, text) {
    if (!safeRelativePath(relpath))
        throw new Error(`unsafe path: ${relpath}`);
    const path = pathInWorkspace(root, relpath);
    GLib.mkdir_with_parents(GLib.path_get_dirname(path), 0o755);
    GLib.file_set_contents(path, text);
}

function bufferText(buffer) {
    const start = buffer.get_start_iter();
    const end = buffer.get_end_iter();
    return buffer.get_text(start, end, true);
}

function setBufferText(buffer, text) {
    buffer.set_text(text, -1);
}

function makeHeader(title, subtitle) {
    const box = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 2,
    });
    box.append(new Gtk.Label({
        label: `<b>${escapeText(title)}</b>`,
        use_markup: true,
        xalign: 0,
    }));
    box.append(new Gtk.Label({
        label: subtitle,
        xalign: 0,
        wrap: true,
    }));
    return box;
}

const app = new Gtk.Application({
    application_id: 'org.altitude.IDE',
    flags: Gio.ApplicationFlags.FLAGS_NONE,
});

app.connect('activate', application => {
    const workspaceRoot = parseWorkspaceRoot();
    const actions = loadActions();
    let visibleFiles = [];
    let visibleActions = [];
    let currentFile = '';
    let dirty = false;

    const win = new Gtk.ApplicationWindow({
        application,
        title: 'Altitude IDE',
        default_width: 1320,
        default_height: 820,
    });

    const root = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 8,
        margin_top: 10,
        margin_bottom: 10,
        margin_start: 10,
        margin_end: 10,
    });

    const topbar = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 10,
    });
    root.append(topbar);

    const title = makeHeader('Altitude IDE', `Workspace: ${workspaceRoot}`);
    title.hexpand = true;
    topbar.append(title);

    const newPathEntry = new Gtk.Entry({
        placeholder_text: 'new file path, e.g. scripts/demo.sh',
        width_chars: 34,
    });
    topbar.append(newPathEntry);

    const newButton = new Gtk.Button({ label: 'New Bash' });
    const saveButton = new Gtk.Button({ label: 'Save' });
    const lintButton = new Gtk.Button({ label: 'Lint' });
    const runScriptButton = new Gtk.Button({ label: 'Run Script' });
    topbar.append(newButton);
    topbar.append(saveButton);
    topbar.append(lintButton);
    topbar.append(runScriptButton);

    const main = new Gtk.Paned({
        orientation: Gtk.Orientation.HORIZONTAL,
        wide_handle: true,
        hexpand: true,
        vexpand: true,
    });
    root.append(main);

    const left = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 6,
        margin_end: 6,
    });
    main.set_start_child(left);

    left.append(makeHeader('Files', 'Open source files from the Altitude workspace.'));

    const fileFilter = new Gtk.Entry({
        placeholder_text: 'filter files',
    });
    left.append(fileFilter);

    const fileList = new Gtk.ListBox({
        selection_mode: Gtk.SelectionMode.SINGLE,
        vexpand: true,
    });
    const fileScroller = new Gtk.ScrolledWindow({
        child: fileList,
        min_content_width: 300,
        hscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
        vscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
        vexpand: true,
    });
    left.append(fileScroller);

    const centerRight = new Gtk.Paned({
        orientation: Gtk.Orientation.HORIZONTAL,
        wide_handle: true,
        hexpand: true,
        vexpand: true,
    });
    main.set_end_child(centerRight);

    const editorBox = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 6,
        margin_start: 6,
        margin_end: 6,
        hexpand: true,
        vexpand: true,
    });
    centerRight.set_start_child(editorBox);

    const fileLabel = new Gtk.Label({
        label: 'No file open',
        xalign: 0,
        selectable: true,
    });
    editorBox.append(fileLabel);

    const editor = new Gtk.TextView({
        editable: true,
        monospace: true,
        hexpand: true,
        vexpand: true,
        wrap_mode: Gtk.WrapMode.NONE,
    });
    const editorBuffer = editor.get_buffer();
    const editorScroller = new Gtk.ScrolledWindow({
        child: editor,
        hexpand: true,
        vexpand: true,
        hscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
        vscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
    });
    editorBox.append(editorScroller);

    const right = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 6,
        margin_start: 6,
    });
    centerRight.set_end_child(right);

    right.append(makeHeader('Agent Actions', 'Run diagnostics and agent helpers without leaving the IDE.'));

    const actionFilter = new Gtk.Entry({
        placeholder_text: 'filter actions',
    });
    right.append(actionFilter);

    const actionArgs = new Gtk.Entry({
        placeholder_text: 'arguments for selected action',
    });
    right.append(actionArgs);

    const runActionButton = new Gtk.Button({ label: 'Run Action' });
    right.append(runActionButton);

    const actionList = new Gtk.ListBox({
        selection_mode: Gtk.SelectionMode.SINGLE,
    });
    const actionScroller = new Gtk.ScrolledWindow({
        child: actionList,
        min_content_width: 310,
        min_content_height: 210,
        hscrollbar_policy: Gtk.PolicyType.NEVER,
        vscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
    });
    right.append(actionScroller);

    const output = new Gtk.TextView({
        editable: false,
        monospace: true,
        hexpand: true,
        vexpand: true,
        wrap_mode: Gtk.WrapMode.WORD_CHAR,
    });
    const outputBuffer = output.get_buffer();
    const outputScroller = new Gtk.ScrolledWindow({
        child: output,
        min_content_width: 310,
        hexpand: true,
        vexpand: true,
        hscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
        vscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
    });
    right.append(outputScroller);

    function setOutput(titleText, text) {
        outputBuffer.set_text(`${titleText}\n${'='.repeat(titleText.length)}\n\n${text}`, -1);
    }

    function refreshFileLabel() {
        const suffix = dirty ? ' *' : '';
        fileLabel.set_text(currentFile ? `${currentFile}${suffix}` : 'No file open');
    }

    function selectedFile() {
        const row = fileList.get_selected_row();
        if (!row)
            return '';
        return visibleFiles[row.get_index()] || '';
    }

    function selectedAction() {
        const row = actionList.get_selected_row();
        if (!row)
            return null;
        return visibleActions[row.get_index()] || null;
    }

    function renderFiles() {
        while (true) {
            const child = fileList.get_first_child();
            if (!child)
                break;
            fileList.remove(child);
        }

        visibleFiles = loadFiles(fileFilter.get_text());
        for (const path of visibleFiles) {
            fileList.append(new Gtk.Label({
                label: path,
                xalign: 0,
                selectable: true,
                margin_top: 5,
                margin_bottom: 5,
                margin_start: 8,
                margin_end: 8,
            }));
        }
    }

    function renderActions() {
        while (true) {
            const child = actionList.get_first_child();
            if (!child)
                break;
            actionList.remove(child);
        }

        const query = actionFilter.get_text().trim().toLowerCase();
        visibleActions = actions.filter(action =>
            query === '' ||
            action.id.toLowerCase().includes(query) ||
            action.label.toLowerCase().includes(query) ||
            action.command.toLowerCase().includes(query)
        );

        for (const action of visibleActions) {
            const box = new Gtk.Box({
                orientation: Gtk.Orientation.VERTICAL,
                spacing: 2,
                margin_top: 7,
                margin_bottom: 7,
                margin_start: 8,
                margin_end: 8,
            });
            box.append(new Gtk.Label({
                label: `<b>${escapeText(action.label)}</b>`,
                use_markup: true,
                xalign: 0,
            }));
            box.append(new Gtk.Label({
                label: `${action.id}\n${action.command}`,
                xalign: 0,
                selectable: true,
            }));
            actionList.append(box);
        }
    }

    function openFile(path) {
        if (!path)
            return;
        try {
            setBufferText(editorBuffer, readFile(workspaceRoot, path));
            currentFile = path;
            dirty = false;
            refreshFileLabel();
            setOutput('Open', `opened ${path}\n`);
        } catch (e) {
            setOutput('Open failed', `${e.message}\n`);
        }
    }

    function saveFile() {
        if (!currentFile) {
            setOutput('Save', 'No file open.\n');
            return;
        }
        try {
            writeFile(workspaceRoot, currentFile, bufferText(editorBuffer));
            dirty = false;
            refreshFileLabel();
            setOutput('Save', `saved ${currentFile}\n`);
        } catch (e) {
            setOutput('Save failed', `${e.message}\n`);
        }
    }

    function runIdeAction(id, args, titleText) {
        const argv = [ALT_IDE_BIN, 'session', 'run', id, ...args];
        setOutput(titleText, 'Running...\n');
        runAsync(argv, text => setOutput(titleText, text));
    }

    function runSelectedAction() {
        const action = selectedAction();
        if (!action) {
            setOutput('Action', 'No action selected.\n');
            return;
        }
        runIdeAction(action.id, shellSplit(actionArgs.get_text()), action.label);
    }

    function createBashFile() {
        const path = newPathEntry.get_text().trim();
        if (!safeRelativePath(path)) {
            setOutput('New Bash', 'Choose a relative path inside the workspace.\n');
            return;
        }
        runIdeAction('language.bash.new', [path], 'New Bash');
        currentFile = path;
        setBufferText(editorBuffer, '#!/usr/bin/env bash\nset -euo pipefail\n\n');
        dirty = true;
        refreshFileLabel();
        GLib.timeout_add(GLib.PRIORITY_DEFAULT, 400, () => {
            renderFiles();
            return GLib.SOURCE_REMOVE;
        });
    }

    editorBuffer.connect('changed', () => {
        if (currentFile) {
            dirty = true;
            refreshFileLabel();
        }
    });

    fileFilter.connect('changed', renderFiles);
    fileList.connect('row-activated', () => openFile(selectedFile()));
    saveButton.connect('clicked', saveFile);
    lintButton.connect('clicked', () => {
        if (!currentFile) {
            setOutput('Bash lint', 'No file open.\n');
            return;
        }
        saveFile();
        runIdeAction('language.bash.lint', [currentFile], 'Bash lint');
    });
    runScriptButton.connect('clicked', () => {
        if (!currentFile) {
            setOutput('Run Script', 'No file open.\n');
            return;
        }
        saveFile();
        runIdeAction('language.bash.run', [currentFile], 'Run Script');
    });
    newButton.connect('clicked', createBashFile);
    newPathEntry.connect('activate', createBashFile);

    actionFilter.connect('changed', renderActions);
    actionList.connect('row-activated', runSelectedAction);
    runActionButton.connect('clicked', runSelectedAction);
    actionArgs.connect('activate', runSelectedAction);

    renderFiles();
    renderActions();
    win.set_child(root);
    win.present();

    runAsync([ALT_IDE_BIN, 'session', 'start', 'ui'], startOutput => {
        runAsync([ALT_IDE_BIN, 'actions', 'run', 'workspace.status'], statusOutput => {
            setOutput('Dashboard', `${startOutput}\n${statusOutput}`);
        });
    });
});

app.run(ARGV);
