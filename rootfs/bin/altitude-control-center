#!/usr/bin/env gjs

imports.gi.versions.Gtk = '4.0';

const ByteArray = imports.byteArray;
const { Gio, GLib, Gtk } = imports.gi;

function bytesToString(bytes) {
    return bytes ? ByteArray.toString(bytes) : '';
}

function runCommand(argv) {
    try {
        const [ok, stdout, stderr, status] =
            GLib.spawn_sync(null, argv, null, GLib.SpawnFlags.SEARCH_PATH, null);
        const out = bytesToString(stdout);
        const err = bytesToString(stderr);
        return `$ ${argv.join(' ')}\n\n${out}${err}${ok ? '' : `\nexit: ${status}\n`}`;
    } catch (e) {
        return `$ ${argv.join(' ')}\n\n${e.message}\n`;
    }
}

const app = new Gtk.Application({
    application_id: 'org.altitude.ControlCenter',
    flags: Gio.ApplicationFlags.FLAGS_NONE,
});

app.connect('activate', application => {
    const win = new Gtk.ApplicationWindow({
        application,
        title: 'Altitude Control Center',
        default_width: 920,
        default_height: 620,
    });

    const root = new Gtk.Box({
        orientation: Gtk.Orientation.VERTICAL,
        spacing: 10,
        margin_top: 14,
        margin_bottom: 14,
        margin_start: 14,
        margin_end: 14,
    });

    const title = new Gtk.Label({
        label: '<b>Altitude Control Center</b>\nHealth, Network, GNOME, systemd, packages and registry audit.',
        use_markup: true,
        xalign: 0,
    });
    root.append(title);

    const buttons = new Gtk.FlowBox({
        selection_mode: Gtk.SelectionMode.NONE,
        max_children_per_line: 5,
        min_children_per_line: 2,
        row_spacing: 8,
        column_spacing: 8,
    });
    const buttonScroller = new Gtk.ScrolledWindow({
        child: buttons,
        hscrollbar_policy: Gtk.PolicyType.NEVER,
        vscrollbar_policy: Gtk.PolicyType.AUTOMATIC,
        min_content_height: 92,
    });
    root.append(buttonScroller);

    const commandBar = new Gtk.Box({
        orientation: Gtk.Orientation.HORIZONTAL,
        spacing: 8,
    });
    root.append(commandBar);

    const commandEntry = new Gtk.Entry({
        text: '/bin/altitude-health summary',
        placeholder_text: 'command to send to Altitude Command Runner',
        hexpand: true,
    });
    commandBar.append(commandEntry);

    const sendButton = new Gtk.Button({ label: 'Send to Terminal' });
    commandBar.append(sendButton);

    const view = new Gtk.TextView({
        editable: false,
        monospace: true,
        hexpand: true,
        vexpand: true,
    });
    const buffer = view.get_buffer();
    const scroller = new Gtk.ScrolledWindow({
        child: view,
        hexpand: true,
        vexpand: true,
    });
    root.append(scroller);

    function show(label, argv) {
        buffer.set_text(`${label}\n${'='.repeat(label.length)}\n\n${runCommand(argv)}`, -1);
    }

    function shell(script) {
        const prelude =
            'export PATH=/bin:/usr/bin:/sbin:/usr/sbin ALTITUDE_AUDIT_LOCK_RETRIES=1; ' +
            't(){ local seconds="$1"; shift; if command -v timeout >/dev/null 2>&1; then timeout "$seconds" "$@"; else "$@"; fi; }; ';
        return ['/bin/bash', '-lc', prelude + script];
    }

    function commandText() {
        return commandEntry.get_text().trim();
    }

    function sendToTerminal() {
        const command = commandText();
        if (command === '') {
            buffer.set_text('Terminal\n========\n\nNo command to send.\n', -1);
            return;
        }
        const quoted = GLib.shell_quote(command);
        show('Terminal', shell(
            '/bin/appreg launch altitude-command-runner >/tmp/altitude-command-runner.log 2>&1 & ' +
            `sleep 1; /bin/terminal-write ${quoted} 2>&1; ` +
            'sleep 1; echo; echo "== registry =="; /bin/bdbreg list /system/terminal 2>&1; ' +
            'echo; echo "== last output =="; cat /run/altitude-command-runner.last 2>/dev/null || true'
        ));
    }

    const actions = [
        ['Status', ['/bin/bash', '-lc',
            'echo "== identity =="; hostname; sed -n "1,8p" /etc/os-release 2>&1; echo; uname -r; ' +
            'echo; echo "== health snapshot =="; /bin/bdbreg list /system/health 2>&1 | sed -n "1,20p"; ' +
            'echo; echo "== network =="; /bin/ip -4 -br a 2>&1; ' +
            'echo; echo "== systemd =="; t 3 systemctl is-system-running 2>&1 || true; ' +
            'echo; echo "== pressure =="; sed -n "1p" /proc/pressure/cpu 2>/dev/null; sed -n "1p" /proc/pressure/io 2>/dev/null'
        ]],
        ['Health', ['/bin/bash', '-lc',
            '/bin/altitude-health summary 2>&1; ' +
            'echo; echo "== registry =="; /bin/bdbreg list /system/health 2>&1; ' +
            'echo; echo "== health log =="; tail -80 /var/log/altitude-health.log 2>&1'
        ]],
        ['Network', ['/bin/bash', '-lc',
            'echo "== address =="; /bin/ip -4 -br a 2>&1; ' +
            'echo; echo "== route =="; ip route 2>&1 || true; ' +
            'echo; echo "== wifi device =="; iw dev 2>&1 || true; ' +
            'echo; echo "== iwlwifi module =="; lsmod 2>/dev/null | grep -E "^iwlwifi|^iwlmvm" || true; ' +
            'echo; echo "== firmware / driver log =="; dmesg 2>/dev/null | grep -Ei "iwlwifi|firmware|wlan|wifi" | tail -80 || true; ' +
            'echo; echo "== services =="; t 8 systemctl status altitude-netmgr.service altitude-wifi.service NetworkManager.service iwd.service wpa_supplicant.service --no-pager -l 2>&1 | sed -n "1,160p"'
        ]],
        ['Network Restart', ['/bin/bash', '-lc',
            'echo "Restarting Altitude network services through systemd..."; ' +
            't 12 /bin/systemd-bridge request restart altitude-netmgr.service 2>&1 || true; ' +
            't 12 /bin/systemd-bridge request restart altitude-wifi.service 2>&1 || true; ' +
            'sleep 2; echo; /bin/altitude-health summary 2>&1; echo; /bin/ip -4 -br a 2>&1; ' +
            'echo; echo "== bridge registry =="; /bin/bdbreg list /system/systemd/bridge 2>&1'
        ]],
        ['GNOME', ['/bin/bash', '-lc',
            'echo "== GNOME =="; ' +
            'pgrep -a gnome-shell || true; ' +
            'echo; t 8 systemctl status altitude-graphical.service altitude-rtkit.service --no-pager -l 2>&1 | sed -n "1,90p"; ' +
            'echo; echo "== RealtimeKit =="; ' +
            'pgrep -a rtkit-daemon || true; ' +
            'busctl --system --no-pager list 2>/dev/null | grep -F org.freedesktop.RealtimeKit1 || true; ' +
            'echo; echo "== Apps =="; ' +
            '/bin/appreg refresh 2>&1; echo; /bin/appreg status 2>&1; echo; /bin/appreg list 2>&1'
        ]],
        ['GNOME Log', ['/bin/bash', '-lc', 'tail -180 /var/log/gnome-shell.log 2>&1']],
        ['GPU', ['/bin/bash', '-lc',
            '/bin/gpu 2>&1; ' +
            'echo; echo "== compositor hints =="; ' +
            'grep -Ei "hardware accelerated|shadow buffer|non-atomic|gbm renderer|nouveau|pmu|gsp|llvmpipe|software" /var/log/gnome-shell.log 2>/dev/null || true; ' +
            'echo; echo "== dri =="; ls -l /dev/dri 2>&1 || true'
        ]],
        ['Performance', ['/bin/bash', '-lc',
            'echo "== pressure =="; cat /proc/pressure/cpu /proc/pressure/memory /proc/pressure/io 2>/dev/null || true; ' +
            'echo; echo "== memory =="; free -h 2>&1 || true; ' +
            'echo; echo "== cpu top =="; ps -eo pid,comm,pcpu,pmem --sort=-pcpu 2>/dev/null | sed -n "1,16p"; ' +
            'echo; echo "== gnome settings =="; gsettings get org.gnome.desktop.interface enable-animations 2>&1 || true'
        ]],
        ['Failures', ['/bin/bash', '-lc',
            'echo "== systemd failed =="; t 5 systemctl --failed --no-pager 2>&1; ' +
            'echo; echo "== recent graphical log =="; tail -80 /var/log/graphical.log 2>&1; ' +
            'echo; echo "== recent GNOME shell log =="; tail -120 /var/log/gnome-shell.log 2>&1'
        ]],
        ['Systemd Bridge', ['/bin/bash', '-lc',
            'echo "== system state =="; t 5 systemctl is-system-running 2>&1 || true; ' +
            'echo; echo "== failed units =="; t 5 systemctl --failed --no-pager 2>&1; ' +
            'echo; echo "== bridge registry =="; /bin/bdbreg list /system/systemd/bridge 2>&1'
        ]],
        ['Registry Audit', ['/bin/bash', '-lc',
            'echo "== system registry snapshot =="; /bin/bdbreg list /system 2>&1; ' +
            'echo; echo "== raw registry table =="; /bin/bdb select registry 2>&1 || /bin/bdb dump registry 2>&1'
        ]],
        ['Packages', ['/bin/bash', '-lc',
            'echo "== configured repositories =="; cat /etc/altitude/repositories.conf 2>&1; ' +
            'echo; echo "== installed =="; /bin/pkg list 2>&1; ' +
            'echo; echo "== available/search =="; t 10 /bin/pkg refresh 2>&1 || true; echo; t 8 /bin/pkg search 2>&1 | sed -n "1,100p"'
        ]],
        ['Apps', ['/bin/bash', '-lc', '/bin/appreg refresh 2>&1; echo; /bin/appreg list 2>&1']],
        ['Terminal State', ['/bin/bash', '-lc',
            'echo "== terminal registry =="; /bin/bdbreg list /system/terminal 2>&1; ' +
            'echo; echo "== last output =="; cat /run/altitude-command-runner.last 2>/dev/null || true; ' +
            'echo; echo "== runner =="; pgrep -a -f "/bin/altitude-command-runner" || true'
        ]],
        ['Open Runner', ['/bin/bash', '-lc', '/bin/appreg launch altitude-command-runner >/tmp/altitude-command-runner.log 2>&1 & echo "Altitude Command Runner requested."']],
    ];

    sendButton.connect('clicked', sendToTerminal);
    commandEntry.connect('activate', sendToTerminal);

    for (const [label, argv] of actions) {
        const button = new Gtk.Button({ label });
        button.connect('clicked', () => show(label, argv));
        buttons.insert(button, -1);
    }

    win.set_child(root);
    win.present();
    show('Status', actions[0][1]);
});

app.run(ARGV);
