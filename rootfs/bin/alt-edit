#!/usr/bin/env bash
set -euo pipefail

POLICY="${ALTITUDE_AGENT_POLICY:-/etc/altitude/agent/policy.conf}"
[ -r "$POLICY" ] && . "$POLICY"

SOURCE_ROOT="${ALTITUDE_AGENT_SOURCE_ROOT:-/root/minibash-linux}"
EDITOR_BIN="${EDITOR:-vi}"

usage() {
  cat <<'USAGE'
usage: alt-edit RELATIVE_PATH

Edit one Altitude source file with a terminal editor. The path must stay inside
the Altitude checkout and start with one of:
  recipes/ scripts/ rootfs/ packages/ docs/ tests/
USAGE
}

die() { echo "alt-edit: $*" >&2; exit 1; }

path="${1:-}"
[ -n "$path" ] || { usage >&2; exit 64; }

case "$path" in
  /*|*'/../'*|../*|*/..|.|'') die "unsafe path: $path" ;;
  recipes/*|scripts/*|rootfs/*|packages/*|docs/*|tests/*) ;;
  *) die "path outside editable Altitude areas: $path" ;;
esac

[ -d "$SOURCE_ROOT" ] || die "source checkout missing: $SOURCE_ROOT"
cd "$SOURCE_ROOT"

mkdir -p "$(dirname "$path")"
echo "alt-edit: $SOURCE_ROOT/$path"
exec "$EDITOR_BIN" "$path"
