#!/usr/bin/env bash
set -euo pipefail

POLICY="${ALTITUDE_AGENT_POLICY:-/etc/altitude/agent/policy.conf}"
[ -r "$POLICY" ] && . "$POLICY"

SOURCE_ROOT="${ALTITUDE_AGENT_SOURCE_ROOT:-/root/minibash-linux}"
[ -d "$SOURCE_ROOT" ] || SOURCE_ROOT="$(pwd)"
ALT_AGENT_BIN="${ALT_IDE_AGENT_BIN:-/bin/alt-agent}"
ALT_DEV_ENV_BIN="${ALT_IDE_DEV_ENV_BIN:-/bin/alt-dev-env}"
ALT_SHELL_LINT_BIN="${ALT_IDE_SHELL_LINT_BIN:-/bin/alt-shell-lint}"
ALT_IDE_STATE_DIR="${ALT_IDE_STATE_DIR:-/run/altitude-ide}"
ALT_IDE_LOG="${ALT_IDE_LOG:-/var/log/altitude/ide.log}"

die() { echo "alt-ide: $*" >&2; exit 1; }
valid_relpath() {
  case "${1:-}" in
    ""|/*|*'/../'*|../*|*/..|.) return 1 ;;
    *) return 0 ;;
  esac
}

project_cd() {
  [ -d "$SOURCE_ROOT" ] || die "workspace missing: $SOURCE_ROOT"
  cd "$SOURCE_ROOT"
}

now_iso() {
  date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date 2>/dev/null || echo unknown
}

session_id() {
  if [ -n "${ALT_IDE_SESSION_ID:-}" ]; then
    printf '%s\n' "$ALT_IDE_SESSION_ID"
  elif [ -r "$ALT_IDE_STATE_DIR/current" ]; then
    sed -n 's/^id=//p' "$ALT_IDE_STATE_DIR/current" | head -n 1
  else
    printf 'none\n'
  fi
}

session_log() {
  local event="$1" detail="${2:-}"
  mkdir -p "$(dirname "$ALT_IDE_LOG")" "$ALT_IDE_STATE_DIR" 2>/dev/null || true
  printf '%s\t%s\t%s\t%s\n' "$(now_iso)" "${ALT_IDE_SESSION_ID:-none}" "$event" "$detail" \
    >> "$ALT_IDE_LOG" 2>/dev/null || true
}

usage() {
  cat <<'USAGE'
usage: alt-ide COMMAND [ARGS...]
       alt-ide PATH

General Altitude IDE command surface. Bash is the first native language, but
the model is language-agnostic: workspace, files, diagnostics, tasks and
language plugins.

Commands:
  workspace status             show workspace, package and tool status
  files list [QUERY]           list project files
  files open PATH              print a project file for IDE frontends
  session start [NAME]         start an observable IDE session
  session status               show current IDE session state
  session run ID [ARGS...]     run and log one action in the session
  session tail [N]             show recent session log lines
  actions list                 list IDE actions for UI/agents
  actions run ID [ARGS...]     run one IDE action by stable id
  diagnostics run [PATH...]    run project diagnostics
  diagnostics quick [PATH...]  run fast diagnostics for current work
  task run NAME                run a named task
  agent context [PATH...]      print agent-ready workspace context
  agent doctor [PATH...]       run focused checks for agent work
  agent plan GOAL...           draft an implementation plan from context
  agent next                   show the next useful IDE/distro upgrades
  language list                list language plugins
  language bash lint [PATH...] lint Bash files
  language bash run PATH       run one Bash script safely from workspace
  language bash new PATH       create a Bash script template and open it
  language bash snippets       list Bash snippets
  language bash snippet ID     print one Bash snippet

Compatibility:
  alt-ide edit PATH
  alt-ide PATH                 print PATH
USAGE
}

cmd_workspace() {
  case "${1:-status}" in
    status)
      echo "Altitude IDE workspace"
      echo "root=$SOURCE_ROOT"
      echo
      "$ALT_AGENT_BIN" status 2>/dev/null || true
      echo
      "$ALT_AGENT_BIN" dev-env 2>/dev/null || "$ALT_DEV_ENV_BIN"
      ;;
    *) die "unknown workspace command: ${1:-}" ;;
  esac
}

cmd_files() {
  local sub="${1:-list}" query="${2:-}"
  project_cd
  case "$sub" in
    list)
      if command -v rg >/dev/null 2>&1; then
        rg --files | { [ -z "$query" ] && cat || grep -i -- "$query"; }
      else
        find . -type f | sed 's#^\./##' |
          { [ -z "$query" ] && cat || grep -i -- "$query"; }
      fi
      ;;
    open)
      local path="${2:-}"
      valid_relpath "$path" || die "unsafe path: $path"
      [ -f "$path" ] || die "file missing: $path"
      echo "path=$path"
      echo
      cat "$path"
      ;;
    *) die "unknown files command: $sub" ;;
  esac
}

cmd_session() {
  local sub="${1:-status}" name id lines
  shift || true
  case "$sub" in
    start)
      name="${1:-ssh}"
      mkdir -p "$ALT_IDE_STATE_DIR" "$(dirname "$ALT_IDE_LOG")" 2>/dev/null || true
      id="$(date -u '+%Y%m%dT%H%M%SZ' 2>/dev/null || echo session)-$$"
      ALT_IDE_SESSION_ID="$id"
      local started_at
      started_at="$(now_iso)"
      {
        echo "id=$id"
        echo "name=$name"
        echo "workspace=$SOURCE_ROOT"
        echo "started_at=$started_at"
      } > "$ALT_IDE_STATE_DIR/current"
      session_log start "name=$name workspace=$SOURCE_ROOT"
      echo "Altitude IDE session started"
      echo "id=$id"
      echo "workspace=$SOURCE_ROOT"
      echo "log=$ALT_IDE_LOG"
      echo
      echo "Follow:"
      echo "  alt-ide session tail"
      echo "Run:"
      echo "  alt-ide session run agent.context"
      ;;
    status)
      if [ -r "$ALT_IDE_STATE_DIR/current" ]; then
        cat "$ALT_IDE_STATE_DIR/current"
      else
        echo "id=none"
        echo "workspace=$SOURCE_ROOT"
      fi
      echo "log=$ALT_IDE_LOG"
      ;;
    run)
      id="${1:-}"
      [ -n "$id" ] || die "usage: alt-ide session run ACTION [ARGS...]"
      shift || true
      ALT_IDE_SESSION_ID="$(session_id)"
      session_log action.start "$id $*"
      if cmd_actions run "$id" "$@"; then
        session_log action.ok "$id"
      else
        local status=$?
        session_log action.fail "$id status=$status"
        return "$status"
      fi
      ;;
    tail)
      lines="${1:-40}"
      [ -r "$ALT_IDE_LOG" ] || { echo "no IDE log: $ALT_IDE_LOG"; return 0; }
      tail -n "$lines" "$ALT_IDE_LOG"
      ;;
    watch)
      [ -r "$ALT_IDE_LOG" ] || touch "$ALT_IDE_LOG" 2>/dev/null || true
      tail -f "$ALT_IDE_LOG"
      ;;
    *) die "unknown session command: $sub" ;;
  esac
}

cmd_diagnostics() {
  local sub="${1:-run}"
  shift || true
  case "$sub" in
    run) exec "$ALT_AGENT_BIN" dev-check "$@" ;;
    quick) exec "$ALT_AGENT_BIN" shell-lint "$@" ;;
    *) die "unknown diagnostics command: $sub" ;;
  esac
}

cmd_actions() {
  local sub="${1:-list}" id
  shift || true
  case "$sub" in
    list)
      cat <<'EOF'
workspace.status	Workspace status	alt-ide workspace status
files.list	List files	alt-ide files list [QUERY]
files.open	Open file	alt-ide files open PATH
diagnostics.run	Full diagnostics	alt-ide diagnostics run
diagnostics.quick	Fast diagnostics	alt-ide diagnostics quick [PATH...]
agent.context	Agent context	alt-ide agent context [PATH...]
agent.doctor	Agent doctor	alt-ide agent doctor [PATH...]
agent.plan	Agent plan	alt-ide agent plan GOAL...
agent.next	Next upgrades	alt-ide agent next
language.bash.lint	Bash lint	alt-ide language bash lint [PATH...]
language.bash.run	Bash run	alt-ide language bash run PATH
language.bash.new	Bash new file	alt-ide language bash new PATH
language.bash.snippets	Bash snippets	alt-ide language bash snippets
language.bash.snippet	Bash snippet	alt-ide language bash snippet ID
task.check	Task check	alt-ide task run check
task.publish	Task publish	alt-ide task run publish
task.audit	Task audit	alt-ide task run audit
EOF
      ;;
    run)
      id="${1:-}"
      [ -n "$id" ] || die "usage: alt-ide actions run ID [ARGS...]"
      shift || true
      case "$id" in
        workspace.status) cmd_workspace status "$@" ;;
        files.list) cmd_files list "$@" ;;
        files.open) cmd_files open "$@" ;;
        diagnostics.run) cmd_diagnostics run "$@" ;;
        diagnostics.quick) cmd_diagnostics quick "$@" ;;
        agent.context) cmd_agent context "$@" ;;
        agent.doctor) cmd_agent doctor "$@" ;;
        agent.plan) cmd_agent plan "$@" ;;
        agent.next) cmd_agent next "$@" ;;
        language.bash.lint) cmd_language bash lint "$@" ;;
        language.bash.run) cmd_language bash run "$@" ;;
        language.bash.new) cmd_language bash new "$@" ;;
        language.bash.snippets) cmd_language bash snippets "$@" ;;
        language.bash.snippet) cmd_language bash snippet "$@" ;;
        task.check) cmd_task run check "$@" ;;
        task.publish) cmd_task run publish "$@" ;;
        task.audit) cmd_task run audit "$@" ;;
        *) die "unknown action id: $id" ;;
      esac
      ;;
    *) die "unknown actions command: $sub" ;;
  esac
}

cmd_task() {
  local sub="${1:-}" name="${2:-}"
  [ "$sub" = run ] || die "usage: alt-ide task run NAME"
  [ -n "$name" ] || die "missing task name"
  case "$name" in
    check) exec "$ALT_AGENT_BIN" dev-check ;;
    lint) exec "$ALT_AGENT_BIN" shell-lint ;;
    status) exec "$ALT_AGENT_BIN" status ;;
    recipes) exec "$ALT_AGENT_BIN" recipes ;;
    publish) exec "$ALT_AGENT_BIN" publish-staging ;;
    audit) exec "$ALT_AGENT_BIN" systemd-audit ;;
    *) die "unknown task: $name" ;;
  esac
}

cmd_agent() {
  local sub="${1:-context}"
  shift || true
  case "$sub" in
    context)
      project_cd
      local pwd_value
      pwd_value="$(pwd)"
      echo "# Altitude IDE Agent Context"
      echo "workspace=$SOURCE_ROOT"
      echo "pwd=$pwd_value"
      echo
      echo "## Tools"
      "$ALT_AGENT_BIN" dev-env 2>/dev/null || "$ALT_DEV_ENV_BIN"
      echo
      echo "## Git"
      if command -v git >/dev/null 2>&1 && [ -d .git ]; then
        git status --short
      else
        echo "git unavailable"
      fi
      echo
      echo "## Focus Files"
      if [ "$#" -gt 0 ]; then
        for path in "$@"; do
          valid_relpath "$path" || die "unsafe path: $path"
          if [ -e "$path" ]; then
            printf '%s\n' "$path"
          else
            printf 'missing:%s\n' "$path"
          fi
        done
      else
        cmd_files list | sed -n '1,80p'
      fi
      ;;
    doctor)
      project_cd
      echo "# Altitude IDE Agent Doctor"
      "$ALT_AGENT_BIN" dev-env 2>/dev/null || "$ALT_DEV_ENV_BIN"
      echo
      "$ALT_AGENT_BIN" shell-lint "$@" 2>/dev/null ||
        "$ALT_SHELL_LINT_BIN" "$@"
      ;;
    plan)
      local goal="$*"
      [ -n "$goal" ] || die "usage: alt-ide agent plan GOAL..."
      project_cd
      cat <<EOF
# Altitude IDE Agent Plan
goal=$goal
workspace=$SOURCE_ROOT

1. Inspect the relevant files and current package ownership.
2. Make the smallest source change that keeps Altitude generic.
3. Run focused diagnostics with: alt-ide agent doctor [PATH...]
4. Run broader checks with: alt-ide diagnostics run
5. Package and publish only after tests pass.

Useful commands:
  alt-ide agent context
  alt-ide files list QUERY
  alt-ide language bash lint PATH
  alt-ide task run check
EOF
      ;;
    next)
      project_cd
      cat <<'EOF'
# Altitude IDE Next Upgrades

1. Package fast navigation tools:
   - git
   - ripgrep
   - make

2. Package real Bash diagnostics:
   - shellcheck
   - shfmt
   - bats

3. Add an IDE UI shell over this command API:
   - read actions from: alt-ide actions list
   - run actions with: alt-ide actions run ID
   - keep logic in CLI, keep UI thin

4. Add language plugins after Bash:
   - c
   - python
   - altitude-recipes
EOF
      ;;
    *) die "unknown agent command: $sub" ;;
  esac
}

cmd_language() {
  local language="${1:-list}"
  shift || true
  case "$language" in
    list)
      echo "bash"
      ;;
    bash)
      cmd_language_bash "$@"
      ;;
    *) die "unknown language plugin: $language" ;;
  esac
}

cmd_language_bash() {
  local sub="${1:-lint}"
  shift || true
  case "$sub" in
    lint)
      exec "$ALT_AGENT_BIN" shell-lint "$@"
      ;;
    run)
      local path="${1:-}"
      valid_relpath "$path" || die "unsafe script path: $path"
      project_cd
      [ -f "$path" ] || die "script missing: $path"
      bash "$path"
      ;;
    new)
      local path="${1:-}"
      valid_relpath "$path" || die "unsafe script path: $path"
      project_cd
      [ ! -e "$path" ] || die "file already exists: $path"
      mkdir -p "$(dirname "$path")"
      {
        echo '#!/usr/bin/env bash'
        echo 'set -euo pipefail'
        echo
      } > "$path"
      chmod +x "$path"
      echo "created=$path"
      ;;
    snippets)
      cat <<'EOF'
strict	Strict Bash header
function	Bash function
main	Main function entrypoint
case	Cleanup case block
args	Argument parser skeleton
confirm	Confirmation prompt
log	Log helpers
service	Systemd service probe
EOF
      ;;
    snippet)
      local id="${1:-}"
      [ -n "$id" ] || die "usage: alt-ide language bash snippet ID"
      case "$id" in
        strict)
          cat <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

EOF
          ;;
        function)
          cat <<'EOF'
my_function() {
  local name="${1:-}"
  [ -n "$name" ] || { echo "missing name" >&2; return 64; }
  echo "$name"
}

EOF
          ;;
        main)
          cat <<'EOF'
main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    help|-h|--help) usage ;;
    *) die "unknown command: $command" ;;
  esac
}

main "$@"
EOF
          ;;
        case)
          cat <<'EOF'
case "${1:-}" in
  start)
    ;;
  stop)
    ;;
  status)
    ;;
  *)
    echo "usage: $0 {start|stop|status}" >&2
    exit 64
    ;;
esac
EOF
          ;;
        args)
          cat <<'EOF'
while [ "$#" -gt 0 ]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
  shift
done
EOF
          ;;
        confirm)
          cat <<'EOF'
confirm() {
  local prompt="${1:-Continue?}"
  local answer
  printf '%s [y/N] ' "$prompt"
  read -r answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

EOF
          ;;
        log)
          cat <<'EOF'
log() {
  printf '%s %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$*" >&2
}

die() {
  log "error: $*"
  exit 1
}

EOF
          ;;
        service)
          cat <<'EOF'
service_state() {
  local unit="${1:?unit required}"
  systemctl is-active "$unit" 2>/dev/null || true
  systemctl is-enabled "$unit" 2>/dev/null || true
}

EOF
          ;;
        *) die "unknown bash snippet: $id" ;;
      esac
      ;;
    *) die "unknown bash command: $sub" ;;
  esac
}

command="${1:-help}"
shift || true

case "$command" in
  workspace) cmd_workspace "$@" ;;
  files) cmd_files "$@" ;;
  session) cmd_session "$@" ;;
  actions) cmd_actions "$@" ;;
  diagnostics) cmd_diagnostics "$@" ;;
  task) cmd_task "$@" ;;
  agent) cmd_agent "$@" ;;
  language) cmd_language "$@" ;;
  edit) cmd_files open "$@" ;;
  help|-h|--help) usage ;;
  *)
    if valid_relpath "$command"; then
      cmd_files open "$command"
    fi
    usage >&2
    die "command not allowed: $command"
    ;;
esac
