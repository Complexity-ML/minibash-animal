#!/usr/bin/env bash
# Native application registry backed by BDB and populated from .desktop files.
set -euo pipefail

export BDB_PATH="${BDB_PATH:-/var/bdb}"
BDB="${BDB_BIN:-/bin/bdb}"
APP_DIRS="${APPREG_DIRS:-/usr/share/applications:/usr/local/share/applications}"
STATE_ROOT="${ALTITUDE_PKG_STATE:-/var/lib/altitude/packages}"

die() { echo "appreg: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
usage: appreg <command> [args]

  refresh             scan .desktop files into app_registry
  list                list registered graphical applications
  status              summarize app registry and package links
  search TERM         search registered applications
  info APP_ID         show one registered application
  launch APP_ID       run the registered Exec command

The registry is derived from standard Linux .desktop files. Apps stay portable;
Altitude adds indexing, policy and package metadata around them.
EOF
}

ensure_bdb() {
  "$BDB" tables >/dev/null 2>&1 && return 0
  mkdir -p "$BDB_PATH"
  if [ -d /etc/minibash/bdb ] && [ ! -f "$BDB_PATH/tables/registry/data.bdb" ]; then
    (cd /etc/minibash/bdb && tar -cf - .) | (cd "$BDB_PATH" && tar -xf -)
  fi
  "$BDB" init >/dev/null 2>&1 || true
}

have_table() { ensure_bdb; "$BDB" tables 2>/dev/null | grep -qx app_registry; }

bdb_retry() {
  local err rc
  err="$(mktemp)"
  for _ in $(seq 1 "${APPREG_BDB_RETRIES:-150}"); do
    if "$BDB" "$@" 2>"$err"; then
      rm -f "$err"
      return 0
    fi
    rc=$?
    if grep -q 'verrou occupe' "$err"; then
      sleep 0.2
      continue
    fi
    cat "$err" >&2
    rm -f "$err"
    return "$rc"
  done
  cat "$err" >&2
  rm -f "$err"
  return 1
}

ensure_table() {
  have_table && return 0
  bdb_retry create app_registry id:text:pk name:text exec:text desktop:text \
    categories:text package:text installed:bool visible:bool description:text \
    >/dev/null
}

desktop_value() {
  local key="$1" file="$2"
  awk -v key="$key" '
    /^\[/ { in_desktop = ($0 == "[Desktop Entry]") }
    in_desktop && index($0, key "=") == 1 {
      print substr($0, length(key) + 2)
      exit
    }
  ' "$file"
}

desktop_id() {
  local file="$1"
  printf '%s' "$(basename "$file" .desktop)" | tr -c 'A-Za-z0-9_.+-' '-'
}

package_for_desktop() {
  local file="$1" id state paths
  for state in "$STATE_ROOT"/*; do
    [ -d "$state" ] || continue
    paths="$state/paths"
    [ -f "$paths" ] || continue
    if grep -qx "payload${file}" "$paths" 2>/dev/null ||
       grep -qx "payload/${file#/}" "$paths" 2>/dev/null; then
      basename "$state"
      return 0
    fi
  done
  id="$(desktop_id "$file")"
  case "$id" in
    altitude-*) echo altitude-core ;;
  esac
}

upsert_app() {
  local id="$1" name="$2" exec="$3" desktop="$4" categories="$5" package="$6" visible="$7" description="$8"
  if "$BDB" select app_registry --where "id=$id" 2>/dev/null | tail -n +2 | grep -q .; then
    bdb_retry update app_registry --where "id=$id" name="$name" exec="$exec" \
      desktop="$desktop" categories="$categories" package="$package" installed=true \
      visible="$visible" description="$description" >/dev/null
  else
    bdb_retry insert app_registry id="$id" name="$name" exec="$exec" \
      desktop="$desktop" categories="$categories" package="$package" installed=true \
      visible="$visible" description="$description" >/dev/null
  fi
}

cmd_refresh() {
  local dir file id type name exec no_display hidden categories package description visible count=0 list seen
  ensure_table
  seen="$(mktemp)"
  IFS=: read -r -a dirs <<< "$APP_DIRS"
  for dir in "${dirs[@]}"; do
    [ -d "$dir" ] || continue
    list="$(mktemp)"
    find "$dir" -maxdepth 1 -type f -name '*.desktop' | sort > "$list"
    while IFS= read -r file; do
      type="$(desktop_value Type "$file")"
      [ "$type" = Application ] || continue
      name="$(desktop_value Name "$file")"
      exec="$(desktop_value Exec "$file")"
      [ -n "$name" ] && [ -n "$exec" ] || continue
      hidden="$(desktop_value Hidden "$file")"
      [ "$hidden" = true ] && continue
      no_display="$(desktop_value NoDisplay "$file")"
      categories="$(desktop_value Categories "$file")"
      description="$(desktop_value Comment "$file")"
      id="$(desktop_id "$file")"
      package="$(package_for_desktop "$file")"
      visible=true
      [ "$no_display" = true ] && visible=false
      upsert_app "$id" "$name" "$exec" "$file" "$categories" "$package" "$visible" "$description"
      printf '%s\n' "$id" >> "$seen"
      count=$((count + 1))
    done < "$list"
    rm -f "$list"
  done
  sort -u "$seen" -o "$seen"
  "$BDB" dump app_registry 2>/dev/null | tail -n +2 | cut -f1 |
    while IFS= read -r old_id; do
      [ -n "$old_id" ] || continue
      grep -qxF "$old_id" "$seen" && continue
      bdb_retry delete app_registry --where "id=$old_id" >/dev/null 2>&1 || true
    done
  rm -f "$seen"
  echo "appreg: indexed $count applications"
}

cmd_list() {
  ensure_table
  printf '%-36s %-28s %-10s %s\n' ID NAME PACKAGE EXEC
  "$BDB" dump app_registry 2>/dev/null | tail -n +2 |
    awk -F '\t' '$8 == "true" {
      printf "%-36s %-28s %-10s %s\n", $1, $2, $6, $3
    }'
}

cmd_status() {
  ensure_table
  "$BDB" dump app_registry 2>/dev/null | tail -n +2 |
    awk -F '\t' '
      BEGIN {
        printf "%-14s %s\n", "KEY", "VALUE"
      }
      {
        total++
        if ($8 == "true") visible++
        else hidden++
        if ($6 != "") packaged++
        else unpackaged++
      }
      END {
        printf "%-14s %d\n", "total", total + 0
        printf "%-14s %d\n", "visible", visible + 0
        printf "%-14s %d\n", "hidden", hidden + 0
        printf "%-14s %d\n", "packaged", packaged + 0
        printf "%-14s %d\n", "unpackaged", unpackaged + 0
      }'
}

cmd_search() {
  local term="${1:-}"
  ensure_table
  "$BDB" dump app_registry 2>/dev/null | tail -n +2 |
    awk -F '\t' -v term="$term" '
      $8 == "true" && (term == "" || index(tolower($1 " " $2 " " $5 " " $9), tolower(term))) {
        printf "%-36s %-28s %-10s %s\n", $1, $2, $6, $9
      }'
}

cmd_info() {
  local id="${1:-}"
  [ -n "$id" ] || die "missing app id"
  ensure_table
  "$BDB" select app_registry --where "id=$id"
}

launch_exec() {
  local command="$1"
  command="${command//%f/}"
  command="${command//%F/}"
  command="${command//%u/}"
  command="${command//%U/}"
  command="${command//%i/}"
  command="${command//%c/}"
  command="${command//%k/}"
  if [ -z "${XDG_RUNTIME_DIR:-}" ] && [ -d /run/user/0 ]; then
    export XDG_RUNTIME_DIR=/run/user/0
  fi
  if [ -z "${WAYLAND_DISPLAY:-}" ] && [ -S "${XDG_RUNTIME_DIR:-/run/user/0}/wayland-0" ]; then
    export WAYLAND_DISPLAY=wayland-0
  fi
  export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-GNOME}"
  export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
  if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
    local pid env
    pid="$(pgrep -x gnome-shell 2>/dev/null | head -n 1 || true)"
    if [ -n "$pid" ] && [ -r "/proc/$pid/environ" ]; then
      env="$(tr '\0' '\n' <"/proc/$pid/environ" |
        sed -n 's/^DBUS_SESSION_BUS_ADDRESS=//p' | head -n 1)"
      [ -n "$env" ] && export DBUS_SESSION_BUS_ADDRESS="$env"
    fi
  fi
  exec /bin/sh -lc "$command"
}

cmd_launch() {
  local id="${1:-}" command
  [ -n "$id" ] || die "missing app id"
  ensure_table
  command="$("$BDB" select app_registry --where "id=$id" 2>/dev/null |
    tail -n +2 | tail -n 1 | cut -f3)"
  [ -n "$command" ] || die "app not found: $id"
  launch_exec "$command"
}

command="${1:-help}"
shift || true
case "$command" in
  refresh) cmd_refresh "$@" ;;
  list) cmd_list "$@" ;;
  status) cmd_status "$@" ;;
  search) cmd_search "$@" ;;
  info) cmd_info "$@" ;;
  launch) cmd_launch "$@" ;;
  help|-h|--help) usage ;;
  *) usage >&2; exit 64 ;;
esac
